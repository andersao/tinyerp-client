{
  "name": "prettus/tinyerp-client",
  "keywords": [
    "tinyerp",
    "erp",
    "api"
  ],
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Anderson Andrade",
      "email": "anderson.asa89@gmail.com"
    }
  ],
  "scripts": {
    "test": "phpunit"
  },
  "autoload": {
    "psr-4": {
      "Prettus\\TinyERP\\": "src/",
      "Prettus\\TinyERP\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "php-http/mock-client": "^1.6",
    "php-http/message": "^1.16",
    "vimeo/psalm": "^5.18"
  },
  "require": {
    "php": "^8.1",
    "illuminate/contracts": "^10.38",
    "nyholm/psr7": "^1.8",
    "php-http/client-common": "^2.7",
    "php-http/discovery": "^1.19",
    "php-http/httplug": "^2.4",
    "psr/http-client-implementation": "^2.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^2.0",
    "symfony/http-client": "^6.4"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
